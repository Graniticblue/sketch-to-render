{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "regions": ["icn1"],
  "functions": {
    "api/generate.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/retouch.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/analyze.ts": {
      "maxDuration": 60
    },
    "api/test-connection.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
